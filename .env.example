# DMMHS Platform — environment configuration
# Copy to .env and fill in values:  copy .env.example .env

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# development | production
NODE_ENV=development

# API port (HTTPS when TLS enabled)
PORT=3847

# HTTP redirect port (redirects to HTTPS on PORT). Set different from PORT when using TLS.
HTTP_PORT=3848

# Bind host (display / redirect URLs)
HOST=localhost

# Enable HTTPS (auto true in production). Development: set true or use OPEN-DASHBOARD.bat --https
USE_HTTPS=false

# Trust X-Forwarded-* headers when behind reverse proxy (production)
TRUST_PROXY=false

# Comma-separated allowed origins for CORS in production
# CORS_ORIGIN=https://dashboard.example.edu.ph

# -----------------------------------------------------------------------------
# Secrets (REQUIRED in production — minimum 64 characters each)
# Generate: npm run generate-secrets
# -----------------------------------------------------------------------------
JWT_SECRET=
SESSION_SECRET=

# Optional: previous JWT secret during rotation (verify old tokens for up to 12h)
# JWT_SECRET_PREVIOUS=

# -----------------------------------------------------------------------------
# TLS / HTTPS (required in production)
# -----------------------------------------------------------------------------
# Production: paths to your CA-signed certificate and private key
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Development with USE_HTTPS=true: leave empty to auto-generate server/certs/dev-*.pem

# HSTS max-age in seconds (default 1 year)
HSTS_MAX_AGE=31536000

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=15
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_WINDOW=1
RATE_LIMIT_STATIC_MAX=200
RATE_LIMIT_STATIC_WINDOW=1
RATE_LIMIT_STORE=memory
# REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_WHITELIST=127.0.0.1,::1
RATE_LIMIT_BLACKLIST=
RATE_LIMIT_SKIP_SUCCESSFUL_LOGIN=true
RATE_LIMIT_PROGRESSIVE_DELAY=true
RATE_LIMIT_ACCOUNT_LOCKOUT=10
RATE_LIMIT_ACCOUNT_LOCKOUT_DURATION=30
RATE_LIMIT_ALERT_THRESHOLD=10
# RATE_LIMIT_STRICT=true
